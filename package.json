{
  "name": "telegram-groq-bot",
  "version": "1.0.0",
  "description": "Telegram бот с интеграцией Groq AI",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node start-combined.js",
    "dev": "node --watch index.js",
    "collector": "node collector-bot.js",
    "collector:dev": "node --watch collector-bot.js",
    "userbot": "node userbot-collector.js",
    "combined": "node combined-bot.js",
    "combined:dev": "node --watch combined-bot.js",
    "backend": "node game21/server/server.js",
    "game:install": "cd game21 && npm run install:all",
    "game:dev": "cd game21 && npm run dev",
    "game:server": "cd game21/server && npm run dev",
    "game:client": "cd game21/client && npm run dev"
  },
  "keywords": [
    "telegram",
    "bot",
    "groq",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "groq-sdk": "^0.8.0",
    "input": "^1.0.1",
    "telegraf": "^4.16.3",
    "telegram": "^2.25.16",
    "tiktoken": "^1.0.22"
  }
}
